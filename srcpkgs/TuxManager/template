# Template file for 'TuxManager'
pkgname=TuxManager
version=1.0.4
revision=1
build_style=qmake
build_wrksrc=src
hostmakedepends="qt6-base qt6-tools"
makedepends="qt6-base-devel qt6-tools-devel"
depends="hicolor-icon-theme"
short_desc="Linux Task Manager alternative built with Qt6"
maintainer="Nafis <mnabid.25@outlook.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/benapetr/TuxManager"
distfiles="https://github.com/benapetr/TuxManager/archive/v${version}.tar.gz"
checksum=634d721139c9042549cd8d41b01feb595c88e81029437cda780faea4a3201b08

do_install() {
	vbin tux-manager
	vinstall ../debian/tux-manager.desktop 644 usr/share/applications
	vinstall tux_manager_icon.svg 644 usr/share/icons/hicolor/scalable/apps tux-manager.svg

	vsed -i "${DESTDIR}/usr/share/applications/tux-manager.desktop" \
		-e 's/^Icon=.*/Icon=tux-manager/'
}
