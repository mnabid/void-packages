# Template file for 'vmware-workstation'
pkgname=vmware-workstation
version=25H2u1
revision=1
_buildver=25219725
_pkgver="${version}_${_buildver}"
archs="x86_64"
create_wrksrc=yes
hostmakedepends="tar sqlite"
depends="fuse gcr gtk+ gtk+3 gtkmm libcanberra libaio pcsclite hicolor-icon-theme
 libxcrypt libxml2 vmware-workstation-dkms-${version}_${revision}"
short_desc="Industry standard for running multiple OSes as VMs on a single Linux PC"
maintainer="Nafis <mnabid.25@outlook.com>"
license="custom:VMware-Workstation"
homepage="https://www.vmware.com/products/workstation-for-linux.html"
repository=nonfree
restricted=yes
nostrip=yes
noverifyrdeps=yes
noshlibprovides=yes
python_version=ignore

# CAUTION: Running macOS on non-Apple hardware is prohibited by Apple
# and is NOT officially supported by VMware.
_fusion_ver=13.5.2
_fusion_buildver=23775688
build_options="macos_guests"
desc_option_macos_guests="Enable macOS guest support"

conf_files="
 /etc/vmware/config
 /etc/conf.d/vmware"
mutable_files="/etc/vmware-installer/database"

distfiles="
